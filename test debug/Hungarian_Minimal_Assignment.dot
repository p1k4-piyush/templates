graph G {
  rankdir=LR;
  node [shape=circle];
  subgraph cluster_L {
    label="Left (1..n)";
    L0 [label="L0 (u=2)"];
    L1 [label="L1 (u=3)"];
    L2 [label="L2 (u=1)"];
  }
  subgraph cluster_R {
    label="Right (1..m)";
    R0 [label="R0 (v=0)"];
    R1 [label="R1 (v=0)"];
    R2 [label="R2 (v=-1)"];
    R3 [label="R3 (v=0)"];
  }
  L0 -- R0 [label="5", style=dotted, color=gray];
  L0 -- R1 [label="2", color=blue, penwidth=2];
  L0 -- R2 [label="1", style=dotted, color=gray];
  L0 -- R3 [label="8", style=dotted, color=gray];
  L1 -- R0 [label="4", style=dotted, color=gray];
  L1 -- R1 [label="10", style=dotted, color=gray];
  L1 -- R2 [label="2", color=blue, penwidth=2];
  L1 -- R3 [label="3", style=dotted, color=gray];
  L2 -- R0 [label="6", style=dotted, color=gray];
  L2 -- R1 [label="7", style=dotted, color=gray];
  L2 -- R2 [label="3", style=dotted, color=gray];
  L2 -- R3 [label="1", color=blue, penwidth=2];
}
