digraph G {
  layout=neato;
  node [shape=circle, style=filled, fillcolor="#F0F8FF"];
  0 [label="0", style=filled, fillcolor=lightgreen];
  1 [label="1"];
  2 [label="2"];
  3 [label="3"];
  0 -> 1 [label="0", color="red", penwidth=2];
  1 -> 2 [label="1", color="red", penwidth=2];
  2 -> 3 [label="2", color="red", penwidth=2];
  3 -> 0 [label="3", color="red", penwidth=2];
  0 -> 2 [label="4", color="red", penwidth=2];
}
