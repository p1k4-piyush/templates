graph G {
  layout=neato;
  node [shape=circle, style=filled, fillcolor="#F0F8FF"];
  0 [label="0"];
  1 [label="1"];
  2 [label="2"];
  3 [label="3"];
  0 -- 1 [color=red, penwidth=2];
  1 -- 2 [color=green, penwidth=2];
  2 -- 0 [color=red, penwidth=2];
  2 -- 3 [color=green, penwidth=2];
  3 -- 1 [color=green, penwidth=2];
}
