graph G {
  layout=neato;
  node [shape=circle];
  0 [label="0"];
  1 [label="1"];
  2 [label="2"];
  3 [label="3"];
  4 [label="4"];
  5 [label="5"];
  6 [label="6"];
  7 [label="7"];
  8 [label="8"];
  9 [label="9"];
  10 [label="10"];
  11 [label="11"];
  12 [label="12"];
  13 [label="13"];
  14 [label="14"];
  0 -- 1;
  1 -- 2;
  2 -- 3;
  3 -- 4;
  4 -- 0;
  5 -- 6;
  6 -- 7;
  7 -- 5;
  8 -- 9;
  9 -- 10;
  10 -- 11;
  11 -- 12;
  12 -- 13;
  13 -- 14;
  14 -- 8;
  0 -- 5 [color="red", penwidth=3];
  7 -- 8 [color="red", penwidth=3];
}
