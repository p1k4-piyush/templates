graph G {
  layout=neato;
  node [shape=circle, style=filled, fillcolor="#F0F8FF"];
  0 [label="0"];
  1 [label="1"];
  2 [label="2"];
  3 [label="3"];
  4 [label="4"];
  5 [label="5"];
  6 [label="6"];
  7 [label="7"];
  8 [label="8"];
  9 [label="9"];
  10 [label="10"];
  11 [label="11"];
  12 [label="12"];
  13 [label="13"];
  14 [label="14"];
  0 -- 1 [color=red, penwidth=2];
  1 -- 2 [color=red, penwidth=2];
  2 -- 3 [color=red, penwidth=2];
  3 -- 4 [color=red, penwidth=2];
  4 -- 0 [color=red, penwidth=2];
  4 -- 5 [color=green, penwidth=2];
  5 -- 6 [color=green, penwidth=2];
  6 -- 4 [color=green, penwidth=2];
  6 -- 7;
  7 -- 8 [color=blue, penwidth=2];
  8 -- 9 [color=blue, penwidth=2];
  9 -- 10 [color=blue, penwidth=2];
  10 -- 7 [color=blue, penwidth=2];
}
