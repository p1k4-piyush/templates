graph G {
  layout=neato;
  node [shape=circle, style=filled, fillcolor="#F0F8FF"];
  0 [label="0"];
  1 [label="1"];
  2 [label="2"];
  3 [label="3"];
  4 [label="4"];
  5 [label="5"];
  6 [label="6"];
  7 [label="7"];
  8 [label="8"];
  9 [label="9"];
  10 [label="10"];
  11 [label="11"];
  12 [label="12"];
  13 [label="13"];
  14 [label="14"];
  1 -- 0 [color="red", penwidth=2];
  2 -- 1 [color="red:invis:green:invis:magenta:invis:orange", penwidth=2, label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="1" color="black"><tr><td bgcolor="white"><font point-size="10" color="red"><b>C0</b></font></td><td bgcolor="white"><font point-size="10" color="green"><b>C1</b></font></td><td bgcolor="white"><font point-size="10" color="magenta"><b>C3</b></font></td><td bgcolor="white"><font point-size="10" color="orange"><b>C4</b></font></td></tr></table>>];
  3 -- 1 [color="orange", penwidth=2];
  4 -- 2;
  5 -- 1 [color="green", penwidth=2];
  6 -- 2 [color="red", penwidth=2];
  7 -- 2 [color="green:invis:magenta", penwidth=2];
  8 -- 4;
  9 -- 1;
  10 -- 3 [color="orange", penwidth=2];
  11 -- 5 [color="green:invis:magenta", penwidth=2];
  12 -- 5 [color="blue", penwidth=2];
  13 -- 11 [color="green:invis:magenta", penwidth=2];
  14 -- 6 [color="red", penwidth=2];
  1 -- 5 [color="magenta", penwidth=2];
  5 -- 12 [color="blue", penwidth=2];
  10 -- 2 [color="orange", penwidth=2];
  0 -- 14 [color="red", penwidth=2];
  7 -- 13 [color="green:invis:magenta", penwidth=2];
}
