graph G {
  node [shape=circle];
  0 [label="0"];
  1 [label="1", style=filled, fillcolor=yellow];
  2 [label="2"];
  3 [label="3", style=filled, fillcolor=yellow];
  0 -- 1 [label="2", color=red, style=dashed, penwidth=2];
  0 -- 2 [label="3"];
  1 -- 2 [label="1", color=red, style=dashed, penwidth=2];
  1 -- 3 [label="4"];
  2 -- 3 [label="2", color=red, style=dashed, penwidth=2];
}
