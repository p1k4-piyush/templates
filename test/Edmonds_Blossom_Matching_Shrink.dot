graph G {
  node [shape=circle];
  0 [label="0"];
  1 [label="1"];
  2 [label="2"];
  3 [label="3"];
  4 [label="4"];
  5 [label="5"];
  0 -- 1 [color=blue, penwidth=2];
  0 -- 2 [style=dotted, color=gray];
  1 -- 2 [style=dotted, color=gray];
  2 -- 3 [color=blue, penwidth=2];
  3 -- 4 [style=dotted, color=gray];
  4 -- 5 [color=blue, penwidth=2];
}
