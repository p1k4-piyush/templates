  12 [label="12"];
  13 [label="13"];
  14 [label="14"];
  1 -- 0;
  2 -- 1;
  3 -- 1 [color="red", penwidth=3];
  4 -- 0;
  5 -- 0 [color="red", penwidth=3];
  6 -- 1;
  7 -- 2;
  8 -- 2;
  9 -- 2;
  10 -- 4;
  11 -- 8;
